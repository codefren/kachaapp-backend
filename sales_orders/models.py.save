from django.conf import settings
from django.db import models


class DeliveryRoute(models.Model):
    class Status(models.TextChoices):
        DRAFT = "draft", "Borrador"
        OPTIMIZED = "optimized", "Optimizada"
        IN_PROGRESS = "in_progress", "En reparto"
        COMPLETED = "completed", "Completada"

    name = models.CharField(max_length=120)
    date = models.DateField()
    driver_name = models.CharField(max_length=120, blank=True)
    max_packages = models.PositiveIntegerField(default=50)
    is_active = models.BooleanField(default=True)
    status = models.CharField(
        max_length=20,
        choices=Status.choices,
        default=Status.DRAFT,
    )
    created_at = models.DateTimeField(auto_now_add=True)

    class Meta:
        ordering = ["-date", "-created_at"]

    def __str__(self):
        return "{} - {}".format(self.name, self.date)


class CustomerOrder(models.Model):
    class Status(models.TextChoices):
        DRAFT = "draft", "Borrador"
        CONFIRMED = "confirmed", "Confirmado"
        PREPARING = "preparing", "En preparación"
        READY = "ready", "Listo"
        OUT_FOR_DELIVERY = "out_for_delivery", "En reparto"
        DELIVERED = "delivered", "Entregado"
        NOT_DELIVERED = "not_delivered", "No entregado"
        CANCELLED = "cancelled", "Cancelado"

    class FulfillmentType(models.TextChoices):
        PICKUP = "pickup", "Recogida"
        DELIVERY = "delivery", "Entrega"

    client = models.ForeignKey(
        "clients.Client",
        on_delete=models.CASCADE,
        related_name="orders",
    )
    created_by = models.ForeignKey(
        settings.AUTH_USER_MODEL,
        on_delete=models.SET_NULL,
        null=True,
        blank=True,
        related_name="customer_orders_created",
    )

    status = models.CharField(
        max_length=30,
        choices=Status.choices,
        default=Status.CONFIRMED,
    )
    fulfillment_type = models.CharField(
        max_length=20,
        choices=FulfillmentType.choices,
        default=FulfillmentType.PICKUP,
    )
    requires_preparation = models.BooleanField(default=True)
    delivery_required = models.BooleanField(default=False)

    notes = models.TextField(blank=True)

    delivery_address = models.TextField(blank=True)
    delivery_notes = models.TextField(blank=True)
    delivery_zone = models.CharField(max_length=120, blank=True)

    delivery_street_type = models.CharField(max_length=50, blank=True)
    delivery_street_name = models.CharField(max_length=255, blank=True)
    delivery_street_number = models.CharField(max_length=50, blank=True)
    delivery_floor = models.CharField(max_length=50, blank=True)
    delivery_postal_code = models.CharField(max_length=20, blank=True)

    delivery_date = models.DateField(null=True, blank=True)
    delivery_time_from = models.TimeField(null=True, blank=True)
    delivery_time_to = models.TimeField(null=True, blank=True)
    delivery_packages = models.PositiveIntegerField(default=1)

    route = models.ForeignKey(
        DeliveryRoute,
        on_delete=models.SET_NULL,
        null=True,
        blank=True,
        related_name="orders",
    )
    route_order = models.PositiveIntegerField(null=True, blank=True)

    scheduled_for = models.DateTimeField(null=True, blank=True)

    received_by_name = models.CharField(max_length=255, blank=True)
    delivered_at = models.DateTimeField(null=True, blank=True)

    not_delivered_reason = models.TextField(blank=True)
    not_delivered_at = models.DateTimeField(null=True, blank=True)

    delivery_driver_name = models.CharField(max_length=255, blank=True)

    # El frontend manda base64/string
    delivery_signature = models.TextField(blank=True)
    delivery_photo = models.TextField(blank=True)

    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)

    class Meta:
        ordering = ["route_order", "-created_at"]

    def __str__(self):
        client_name = getattr(self.client, "name", "Sin cliente")
        return "Pedido #{} - {}".format(self.id, client_name)


class CustomerOrderItem(models.Model):
    order = models.ForeignKey(
        CustomerOrder,
        on_delete=models.CASCADE,
        related_name="items",
    )
    product = models.ForeignKey(
        "proveedores.Product",
        on_delete=models.CASCADE,
        related_name="customer_order_items",
    )
    quantity = models.PositiveIntegerField(default=1)
    created_at = models.DateTimeField(auto_now_add=True)

    class Meta:
        ordering = ["-created_at"]

    def __str__(self):
       return "Pedido #{} - Producto #{} x {}".format(self.order_id, self.product_id, self.quantity)

